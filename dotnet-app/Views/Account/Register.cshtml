@model RegisterInputModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="row justify-content-center py-3 py-md-4">
    <div class="col-12 col-md-7 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <h2 class="h4 mb-1">Create your account</h2>
                    <p class="text-muted mb-0">Get access to your finance tracker workspace.</p>
                </div>

                <form asp-action="Register" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input asp-for="ReturnUrl" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold"></label>
                <input asp-for="Email" class="form-control" autocomplete="email" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold"></label>
                <input asp-for="Password" class="form-control" autocomplete="new-password" placeholder="Minimum 8 characters" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Re-enter password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

                    <button type="submit" class="btn btn-primary w-100">Create Account</button>
                </form>

                <p class="mt-3 mb-0 text-center small">
                    Already have an account?
                    <a asp-action="Login" asp-route-returnUrl="@Model.ReturnUrl" class="fw-semibold">Sign in</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

