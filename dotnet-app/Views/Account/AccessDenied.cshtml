@{
    ViewData["Title"] = "Access Denied";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-7 col-lg-6">
        <div class="card shadow-sm auth-card text-center">
            <div class="card-body p-4 p-md-5">
                <h2 class="page-title mb-2">Access denied</h2>
                <p class="text-muted mb-4">Your account is signed in, but it does not have permission to view this page.</p>
                <div class="d-flex justify-content-center gap-2 flex-wrap">
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary">Go to dashboard</a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">Switch account</a>
                </div>
            </div>
        </div>
    </div>
</div>

