<!DOCTYPE html>
<html lang="en">
@inject FinanceTracker.Web.Application.Services.ActiveCompanyContext ActiveCompanyContext
@inject FinanceTracker.Web.Application.Services.CompanyService CompanyService
@inject FinanceTracker.Web.Application.Services.ProjectTypeService ProjectTypeService
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " – Finance Tracker" : "Finance Tracker")</title>

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#1e3a5f" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Finance Tracker" />
    <link rel="apple-touch-icon" href="/favicon.ico" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = (string?)ViewContext.RouteData.Values["controller"] ?? string.Empty;
        var currentPathWithQuery = $"{Context.Request.Path}{Context.Request.QueryString}";
        var loginReturnUrl = currentController.Equals("Account", StringComparison.OrdinalIgnoreCase)
            ? null
            : currentPathWithQuery;

        var companies = User.Identity?.IsAuthenticated == true
            ? (await CompanyService.GetAllForCurrentUserAsync(CancellationToken.None)) ?? []
            : [];
        var projectTypes = User.Identity?.IsAuthenticated == true
            ? (await ProjectTypeService.GetAllAsync(CancellationToken.None)) ?? []
            : [];
    }
    <header>
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container-fluid px-3">

                <!-- ① Brand -->
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-graph-up-arrow"></i>Finance Tracker
                </a>

                <!-- ② Right-side controls – ALWAYS VISIBLE (outside collapse) -->
                <div class="d-flex align-items-center gap-1 ms-auto me-2" id="navbarControls">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (ActiveCompanyContext.Company is not null)
                        {
                            <div class="dropdown">
                                <button class="btn btn-navbar-company dropdown-toggle" type="button"
                                        id="companyDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-building me-1"></i>
                                    <span>@ActiveCompanyContext.Company.Name</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="companyDropdown">
                                    <li><h6 class="dropdown-header"><i class="bi bi-building me-1"></i>Your Companies</h6></li>
                                    @foreach (var company in companies)
                                    {
                                        var isActive = ActiveCompanyContext.Company?.Id == company.Id;
                                        <li>
                                            <form asp-controller="Companies" asp-action="SetDefault" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="companyId" value="@company.Id" />
                                                <input type="hidden" name="returnUrl" value="@Url.Action("Index","Dashboard")" />
                                                <button type="submit" class="dropdown-item @(isActive ? "active" : "")">
                                                    <i class="bi @(isActive ? "bi-check-circle-fill" : "bi-circle") me-2"></i>@company.Name
                                                </button>
                                            </form>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Companies" asp-action="Index">
                                            <i class="bi bi-buildings me-2"></i>Manage Companies
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }

                        <div class="dropdown">
                            <button class="btn btn-navbar-user dropdown-toggle d-flex align-items-center gap-1"
                                    type="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle"></i>
                                <span class="d-none d-sm-inline">@User.Identity?.Name?.Split('@')[0]</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                <li>
                                    <h6 class="dropdown-header">
                                        <i class="bi bi-envelope me-1"></i>@User.Identity?.Name
                                    </h6>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="w-100">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Sign Out
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@loginReturnUrl"
                           class="btn btn-navbar-user btn-sm me-1">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
                        </a>
                        <a asp-controller="Account" asp-action="Register" asp-route-returnUrl="@loginReturnUrl"
                           class="btn btn-navbar-company btn-sm">
                            <i class="bi bi-person-plus me-1"></i>Register
                        </a>
                    }
                </div>

                <!-- ③ Toggler -->
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- ④ Collapsible nav links -->
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentController=="Dashboard"?"active":"")"
                                   asp-controller="Dashboard" asp-action="Index">
                                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController=="Companies"?"active":"")"
                                   asp-controller="Companies" asp-action="Index">
                                    <i class="bi bi-building me-1"></i>Companies
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController=="Projects"?"active":"")"
                                   asp-controller="Projects" asp-action="Index">
                                    <i class="bi bi-folder me-1"></i>Projects
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(currentController=="ProjectTypes"?"active":"")"
                                   href="#" id="projectTypesDropdown" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-tag me-1"></i>Company Types
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="projectTypesDropdown">
                                    @foreach (var type in projectTypes)
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="ProjectTypes" asp-action="Index">
                                                @type.Name
                                            </a>
                                        </li>
                                    }
                                    @if (projectTypes.Any()) { <li><hr class="dropdown-divider" /></li> }
                                    <li>
                                        <a class="dropdown-item" asp-controller="ProjectTypes" asp-action="Index">
                                            <i class="bi bi-list me-1"></i>Manage All
                                        </a>
                                    </li>
                                </ul>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController=="Categories"?"active":"")"
                                   asp-controller="Categories" asp-action="Index">
                                    <i class="bi bi-tags me-1"></i>Categories
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentController=="Backup"?"active":"")"
                                   asp-controller="Backup" asp-action="Index">
                                    <i class="bi bi-cloud-arrow-up me-1"></i>Backup
                                </a>
                            </li>
                        }
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <main class="container py-4">
        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@success
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@error
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="app-footer">
        <i class="bi bi-heart-fill text-danger me-1"></i>Designed &amp; developed by Masum
        <span class="mx-2">·</span>
        <a href="mailto:md.wr.masum@gmail.com"><i class="bi bi-envelope me-1"></i>md.wr.masum@gmail.com</a>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @{
        var modalTarget = TempData["ModalTarget"] as string;
        var modalError  = TempData["ModalError"] as string;
    }
    @if (!string.IsNullOrEmpty(modalTarget))
    {
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var el = document.getElementById('@modalTarget');
                if (!el) return;
                var errMsg = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(modalError ?? ""));
                if (errMsg) {
                    var errDiv = el.querySelector('.modal-error-alert');
                    if (errDiv) { errDiv.textContent = errMsg; errDiv.classList.remove('d-none'); }
                }
                if (el.classList.contains('offcanvas')) {
                    bootstrap.Offcanvas.getOrCreateInstance(el).show();
                } else {
                    bootstrap.Modal.getOrCreateInstance(el).show();
                }
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)

    <!-- PWA Service Worker Registration -->
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function () {
                navigator.serviceWorker.register('/sw.js')
                    .catch(function (err) { console.warn('SW registration failed:', err); });
            });
        }
    </script>
</body>
</html>
