@model IReadOnlyList<Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="page-title mb-0">Categories</h2>
    <a asp-action="Create" class="btn btn-primary">New Category</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No categories yet.</div>
}
else
{
    <div class="row g-3">
        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header fw-semibold text-danger">Expense</div>
                <ul class="list-group list-group-flush">
                    @foreach (var cat in Model.Where(x => x.Type == TransactionType.Expense))
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@cat.Name</span>
                            <span>
                                <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete category?');">
                                    <input type="hidden" name="id" value="@cat.Id" />
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </span>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header fw-semibold text-success">Income</div>
                <ul class="list-group list-group-flush">
                    @foreach (var cat in Model.Where(x => x.Type == TransactionType.Income))
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@cat.Name</span>
                            <span>
                                <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete category?');">
                                    <input type="hidden" name="id" value="@cat.Id" />
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
}
