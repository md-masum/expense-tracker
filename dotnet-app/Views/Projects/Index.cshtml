@model IReadOnlyList<Project>
@{
    ViewData["Title"] = "Projects";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="page-title mb-0">Projects</h2>
    <a asp-action="Create" class="btn btn-primary">New Project</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No projects yet.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Name</td>
                    <td><span class="badge text-bg-secondary">@p.Type</span></td>
                    <td>@p.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td class="text-end">
                        <a asp-controller="Transactions" asp-action="Index" asp-route-projectId="@p.Id" class="btn btn-sm btn-outline-primary">Transactions</a>
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this project and all transactions?');">
                            <input type="hidden" name="id" value="@p.Id" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
