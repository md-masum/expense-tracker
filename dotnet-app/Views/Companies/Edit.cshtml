@model CompanyInputModel
@{
    ViewData["Title"] = "Edit Company";
}

<h2 class="page-title">Edit Company</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data" class="card card-body shadow-sm">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="ExistingImageUrl" type="hidden" />

    <div class="row g-3">
        <div class="col-12">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="col-12">
            @if (!string.IsNullOrWhiteSpace(Model.ExistingImageUrl))
            {
                <div class="mb-2">
                    <img src="@Model.ExistingImageUrl" alt="Current banner" style="max-width:320px;height:auto" class="rounded border" />
                </div>
            }
            <label asp-for="BannerImage" class="form-label">Replace Banner Image</label>
            <input asp-for="BannerImage" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
            <div class="form-text">Leave empty to keep current banner.</div>
            <span asp-validation-for="BannerImage" class="text-danger"></span>
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-primary" type="submit">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

